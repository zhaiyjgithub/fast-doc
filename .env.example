# Copy this file to .env and fill in real values
# Never commit .env to version control

DATABASE_URL=postgresql+asyncpg://emr:emr123@localhost:5433/emr_dev
TEST_DATABASE_URL=postgresql+asyncpg://emr:emr123@localhost:5433/emr_test

QWEN_API_KEY=sk-your-key-here
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_CHAT_MODEL=qwen-max
QWEN_EMBEDDING_MODEL=text-embedding-v3
QWEN_VL_MODEL=qwen-vl-max
EMBEDDING_DIM=1024

# Generate with: python -c "import base64,os; print(base64.b64encode(os.urandom(32)).decode())"
ENCRYPTION_KEY=base64-encoded-32-bytes-here

MINERU_API_KEY=your-mineru-token-here
MINERU_SINGLE_URL=https://mineru.net/api/v4/extract/task
MINERU_BATCH_UPLOAD_URL=https://mineru.net/api/v4/file-urls/batch
MINERU_SINGLE_POLL_URL=https://mineru.net/api/v4/extract/task/{task_id}
MINERU_MODEL_VERSION=vlm
MINERU_LANGUAGE=en
MINERU_POLL_INTERVAL=10
MINERU_MAX_WAIT=900
IMAGE_DESCRIPTION_ENABLED=true
