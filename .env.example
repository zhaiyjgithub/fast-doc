# Copy this file to .env and fill in real values
# Never commit .env to version control

# ──────────────────────────────────────────────
# PostgreSQL
# ──────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://agent:agent123@localhost:5432/agent_db
TEST_DATABASE_URL=postgresql+asyncpg://agent:agent123@localhost:5432/emr_test

# ──────────────────────────────────────────────
# Qwen (DashScope)
# ──────────────────────────────────────────────
QWEN_API_KEY=sk-REPLACE_WITH_YOUR_DASHSCOPE_KEY
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_CHAT_MODEL=qwen-plus
QWEN_EMBEDDING_MODEL=text-embedding-v3
QWEN_VL_MODEL=qwen-vl-max
EMBEDDING_DIM=1024

# ──────────────────────────────────────────────
# MinerU Token-based 精准解析 API (v4)
# 获取: https://mineru.net/apiManage/token
# ──────────────────────────────────────────────
MINERU_API_KEY=REPLACE_WITH_YOUR_MINERU_JWT_TOKEN
MINERU_SINGLE_URL=https://mineru.net/api/v4/extract/task
MINERU_BATCH_UPLOAD_URL=https://mineru.net/api/v4/file-urls/batch
MINERU_SINGLE_POLL_URL=https://mineru.net/api/v4/extract/task/{task_id}
MINERU_BATCH_POLL_URL=https://mineru.net/api/v4/extract-results/batch/{batch_id}
MINERU_MODEL_VERSION=vlm
MINERU_LANGUAGE=en
MINERU_POLL_INTERVAL=10
MINERU_MAX_WAIT=900

# ──────────────────────────────────────────────
# PHI Encryption key (AES-256-GCM)
# 生成: python -c "import base64,os; print(base64.b64encode(os.urandom(32)).decode())"
# ──────────────────────────────────────────────
ENCRYPTION_KEY=REPLACE_WITH_BASE64_32_BYTES

# ──────────────────────────────────────────────
# Feature flags
# ──────────────────────────────────────────────
IMAGE_DESCRIPTION_ENABLED=true
